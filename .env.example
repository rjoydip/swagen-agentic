# ─── AI provider (one required) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── API under test ───────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3000
API_TOKEN=your-bearer-token-here

# ─── GitHub bot ───────────────────────────────────────────────────────────────
GH_TOKEN=ghp_...
GITHUB_REPOSITORY=owner/repo

# ─── GitHub App webhook server ────────────────────────────────────────────────
WEBHOOK_SECRET=your-webhook-secret
APP_MODE=actions  # or "webhook"
PORT=3000

# ─── swagen config overrides ──────────────────────────────────────────────────
SWAGEN_SPEC_PATH=openapi.yaml
SWAGEN_OUT_DIR=__tests__/api
SWAGEN_RUNNER=bun
SWAGEN_DRY_RUN=false
SWAGEN_AUTO_COMMIT=false
SWAGEN_RUN_TESTS=false
SWAGEN_AI_PROVIDER=anthropic
SWAGEN_AI_MODEL=claude-opus-4-5-20251101

# ─── Redis storage (optional) ─────────────────────────────────────────────────
# REDIS_TOKEN=your-upstash-rest-token
# STORAGE_REDIS_URL=https://your-instance.upstash.io
